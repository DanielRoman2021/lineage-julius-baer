# Copy to .env and fill in. With NO key set, the app runs in DEMO MODE (canned
# artifacts) so the full demo works offline. Set the key for LIVE Anthropic agents.
ANTHROPIC_API_KEY=

# Model tiers (override if needed). Specialists run the parallel fan-out; the
# synthesis tier handles the coordinator / compliance / communication reasoning.
ANTHROPIC_MODEL_SPECIALIST=claude-sonnet-4-6
ANTHROPIC_MODEL_SYNTHESIS=claude-opus-4-8

# Confidence below this auto-escalates an extraction/classification to a human.
CONFIDENCE_THRESHOLD=0.70

# Comma-separated allowed CORS origins for the Next.js frontend.
CORS_ORIGINS=http://localhost:3000

# MongoDB Atlas. With no URI set, the app falls back to the bundled JSON seed.
MONGODB_URI=
MONGODB_DB=lineage
